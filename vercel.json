{
  "functions": {
    "api/scrape.js": {
      "includeFiles": "scraper/**",
      "maxDuration": 110
    },
    "api/leads-data.js": {
      "includeFiles": "data/**"
    },
    "api/state.js": {
      "includeFiles": "data/**"
    }
  },
  "crons": [
    { "path": "/api/scrape", "schedule": "0 2 * * *" },
    { "path": "/api/scrape", "schedule": "0 6 * * *" },
    { "path": "/api/scrape", "schedule": "0 10 * * *" },
    { "path": "/api/scrape", "schedule": "0 14 * * *" },
    { "path": "/api/scrape", "schedule": "0 18 * * *" },
    { "path": "/api/scrape", "schedule": "0 22 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
